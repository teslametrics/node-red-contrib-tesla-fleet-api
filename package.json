  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test"
  },
  "node-red": {
    "version": ">=3.0.0",
    "nodes": {
      "tesla-fleet-config": "nodes/tesla-fleet-config.js",
      "tesla-fleet-single-metric": "nodes/tesla-fleet-single-metric.js",
      "tesla-fleet-multiple-metrics": "nodes/tesla-fleet-multiple-metrics.js"
    }
  },
  "files": [
    "lib/",
